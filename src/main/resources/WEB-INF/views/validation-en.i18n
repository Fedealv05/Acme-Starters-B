acme.validation.header.message  	= Must have from 1 to 75 characters
acme.validation.text.message   		= Must have from 1 to 255 characters
acme.validation.phone.message       = Must match +country-code (area-code) phone-number, where only the phone-number is mandatory 
acme.validation.ticker.message = The ticker must follow the format XX99-YYYYY (2 uppercase letters, 2 digits, a hyphen, and between 5 and 10 alphanumeric characters).
acme.validation.strategy.duplicated-ticker.message 	= A strategy with this ticker already exists
acme.validation.strategy.timeInterval.message 		= The end date must be strictly after the start date
acme.validation.strategy.tactics.message 			= You cannot publish a strategy that does not have at least one tactic

acme.validation.tactic.percentage.message = The sum of the expected percentages of all tactics cannot exceed 100%


acme.validation.sponsorship.duplicated-ticker.message 	= A sponsorship with this ticker already exists
acme.validation.sponsorship.timeInterval.message 		= The end date must be strictly after the start date
 sponsorship.publish.validation.hasAtLeastOneDonation 			= You cannot publish a sponsorship that does not have at least one donation
acme.validation.moneyWithCurrency.isEur.message = The only allowed currency is EUR
acme.valid.invention.duplicated-ticker.message = An invention with this ticker already exists
acme.validation.invention.timeInterval.message = The end date must be strictly after the start date
acme.validation.invention.parts.message = You cannot publish an invention that does not have at least one part
invention.publish.validation.hasAtLeastOnePart = You cannot publish an invention that does not have at least one part
invention.publish.validation.validStartMoment = The start moment must be after the publishing time
invention.publish.validation.validEndMoment = The start moment must be after the publishing time
acme.validation.sponsorship.invalid-interval.message = Invalid time interval
acme.valid.campaign.duplicated-ticker.message = A campaign with this ticker already exists
acme.validation.campaign.timeInterval.message = The end date must be strictly after the start date
acme.validation.campaign.milestones.message = You cannot publish a campaign that does not have at least one milestone
campaign.publish.validation.hasAtLeastOneMilestone = You cannot publish a campaign that does not have at least one milestone
campaign.publish.validation.validStartMoment = The start moment must be after the publishing time
campaign.publish.validation.validEndMoment = The end moment must be after the publishing time




